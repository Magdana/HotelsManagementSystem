{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "HmsJwtSuperSecretKeyThatIsAtLeast32Characters!",
    "Issuer": "HMS.WebAPI",
    "Audience": "HMS.Client",
    "ExpirationInMinutes": 1440
  }

}
